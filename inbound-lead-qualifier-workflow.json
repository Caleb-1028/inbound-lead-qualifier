      "id": "15f3d6ef-6a82-48ba-bd95-c57f61631bc1",
      "name": "AI Lead Scoring",
      "credentials": {
        "openAiApi": {
          "id": "wcAJwfpsLsqzv30U",
          "name": "OpenAi account"
        }
      }
