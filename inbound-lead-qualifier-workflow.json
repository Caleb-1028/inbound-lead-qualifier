    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const original = $('Normalize Lead Data').item.json;\nconst current = $input.item.json;\n\nconst rawText =\n  current.output?.[0]?.content?.[0]?.text ?? \"\";\n\nconst cleanedText = rawText\n  .replace(/^```json\\s*/i, \"\")\n  .replace(/^```\\s*/i, \"\")\n  .replace(/\\s*```$/i, \"\")\n  .trim();\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(cleanedText);\n} catch (error) {\n  parsed = {\n    lead_score: 0,\n    qualified: false,\n    segment: \"unknown\",\n    priority: \"low\",\n    reason: \"Could not parse AI output\"\n  };\n}\n\nconst aiScore = Number(parsed.lead_score ?? 0);\n\nlet aiTier = \"cold\";\nif (parsed.priority === \"high\") {\n  aiTier = \"hot\";\n} else if (parsed.priority === \"medium\") {\n  aiTier = \"warm\";\n}\n\nlet aiAction = \"manual_review\";\nif (parsed.qualified === true && aiTier === \"hot\") {\n  aiAction = \"route_to_sales\";\n} else if (parsed.qualified === true && aiTier === \"warm\") {\n  aiAction = \"review\";\n}\n\nreturn {\n  json: {\n    submittedAt: original.submittedAt ?? \"\",\n    fullName: original.fullName ?? \"\",\n    email: original.email ?? \"\",\n    company: original.company ?? \"\",\n    jobTitle: original.jobTitle ?? \"\",\n    employeeCount: original.employeeCount ?? \"\",\n    source: original.source ?? \"\",\n    message: original.message ?? \"\",\n\n    lead_score: aiScore,\n    qualified: Boolean(parsed.qualified),\n    segment: parsed.segment ?? \"unknown\",\n    priority: parsed.priority ?? \"low\",\n    reason: parsed.reason ?? \"\",\n\n    aiScore,\n    aiTier,\n    aiReason: parsed.reason ?? \"\",\n    aiAction,\n\n    workflowVersion: \"v1\"\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        0
      ],
